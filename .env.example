# =============================================================================
# AI Avatar Companion — Environment Configuration
# =============================================================================
# Copy this file to `.env.local` and fill in your real keys.
# Never commit `.env.local` to git.
# =============================================================================

# ---- AI Provider (choose ONE) ----

# Option A: Anthropic Claude (default, recommended)
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Option B: OpenAI (uncomment and use these instead)
# OPENAI_API_KEY=your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini

# Option C: Google AI Studio / Gemini (uncomment and use these instead)
# Get a key at https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your-google-ai-studio-key-here
# GOOGLE_MODEL=gemini-2.0-flash

# Which provider to use: "anthropic", "openai", or "google"
AI_PROVIDER=anthropic

# ---- Assistant identity (safe to change) ----
ASSISTANT_NAME=Mira
ASSISTANT_PERSONA="warm, intelligent, professional, gently playful"

# ---- Optional: external TTS provider (e.g. ElevenLabs) ----
# Leave blank to use the browser's built-in SpeechSynthesis (default for MVP).
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# ---- Live video avatar (Simli) ----
# When both are set, the avatar becomes a real-time lip-synced video.
# If unset, the app falls back to the static image + browser voice.
# Get a key + face id at https://app.simli.com/
# SIMLI_API_KEY=your-simli-api-key
# SIMLI_FACE_ID=your-simli-face-id

# Voice that drives the avatar's lips (used only when Simli is enabled).
# Reuses your Google AI Studio key. Pick any voice: Kore, Aoede, Puck,
# Charon, Leda, Zephyr, etc. (see Gemini speech-generation docs).
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore

# TTS is resilient: if a model fails or doesn't respond, the server
# automatically falls back to the next one. The chain is GEMINI_TTS_MODEL
# first, then GEMINI_TTS_MODELS (comma-separated), then built-in defaults
# (gemini-2.5-flash-preview-tts, gemini-3.1-flash-tts-preview,
# gemini-2.5-pro-preview-tts). Override the fallback order here if you like:
# GEMINI_TTS_MODELS=gemini-3.1-flash-tts-preview,gemini-2.5-flash-preview-tts
